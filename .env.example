# Discord token (required)
DISCORD_TOKEN=

# Optional API keys
YOUTUBE_API_KEY=
# Spotify credentials MUST be from a PREMIUM account for playlist/album access
# Free Spotify accounts cannot use the API for playlist items (403 error)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GENIUS_ACCESS_TOKEN=

# Lyrics fallback / config
LRCLIB_BASE_URL=https://lrclib.net

# Bot settings
DEFAULT_VOLUME=50
DEFAULT_LANGUAGE=en
PRIMARY_SOURCE=youtube
SUPPORTED_SOURCES=youtube,spotify

# Paths / runtime
CACHE_DIR=./cache
VOICE_TIMEOUT=300
IDLE_DISCONNECT_TIME=600
DEBUG=false
